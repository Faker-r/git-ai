            "content": "/// Performance profiling test for Cursor DB operations.\n///\n/// This test is `#[ignore]` so it never runs in CI or normal `cargo test`.\n/// It exercises the CursorPreset code paths that `collect_context_conversations`\n/// uses in the post-commit hook, timing each stage individually.\n///\n/// Run with:\n/// ```\n/// GIT_AI_DEBUG=1 cargo test --test integration cursor_perf -- --ignored --nocapture\n/// ```\n///\n/// By default it auto-detects the Cursor global DB at the standard macOS path.\n/// Override with GIT_AI_CURSOR_PERF_DB_PATH or GIT_AI_CURSOR_GLOBAL_DB_PATH.\nuse git_ai::commands::checkpoint_agent::agent_presets::CursorPreset;\nuse std::path::PathBuf;\nuse std::time::Instant;\n\nfn expand_tilde(p: &str) -> PathBuf {\n    if let Some(rest) = p.strip_prefix(\"~/\") {\n        if let Some(home) = dirs::home_dir() {\n            return home.join(rest);\n        }\n    }\n    PathBuf::from(p)\n}\n\nfn resolve_db_path() -> Option<PathBuf> {\n    if let Ok(p) = std::env::var(\"GIT_AI_CURSOR_PERF_DB_PATH\") {\n        let path = expand_tilde(&p);\n        if path.exists() {\n            return Some(path);\n        }\n        eprintln!(\"GIT_AI_CURSOR_PERF_DB_PATH={} does not exist\", path.display());\n        return None;\n    }\n    if let Ok(p) = std::env::var(\"GIT_AI_CURSOR_GLOBAL_DB_PATH\") {\n        let path = PathBuf::from(p);\n        if path.exists() {\n            return Some(path);\n        }\n    }\n    // Auto-detect default macOS path\n    if let Some(home) = dirs::home_dir() {\n        let default = home\n            .join(\"Library\")\n            .join(\"Application Support\")\n            .join(\"Cursor\")\n            .join(\"User\")\n            .join(\"globalStorage\")\n            .join(\"state.vscdb\");\n        if default.exists() {\n            return Some(default);\n        }\n    }\n    None\n}\n\n#[test]\n#[ignore]\nfn cursor_db_performance_profile() {\n    let db_path = match resolve_db_path() {\n        Some(p) => p,\n        None => {\n            eprintln!(\n                \"Skipping: set GIT_AI_CURSOR_PERF_DB_PATH to your Cursor state.vscdb path\"\n            );\n            return;\n        }\n    };\n\n    let file_size_mb = std::fs::metadata(&db_path)\n        .map(|m| m.len() as f64 / 1_048_576.0)\n        .unwrap_or(0.0);\n\n    // Resolve a workspace path for filtering (use cwd as a reasonable default)\n    let workspace_path = std::env::current_dir().unwrap_or_else(|_| PathBuf::from(\".\"));\n\n    eprintln!(\"=== Cursor DB Performance Profile ===\");\n    eprintln!(\"Database: {}\", db_path.display());\n    eprintln!(\"Size: {:.1} MB\", file_size_mb);\n    eprintln!(\"Workspace filter: {}\", workspace_path.display());\n    eprintln!();\n\n    // Stage 1: list_workspace_conversation_ids (single-query approach)\n    let t = Instant::now();\n    let workspace_ids = CursorPreset::list_workspace_conversation_ids(&db_path, &workspace_path)\n        .expect(\"Failed to list workspace conversation IDs\");\n    let list_elapsed = t.elapsed();\n    eprintln!(\n        \"[1] list_workspace_conversation_ids: {:?} ({} conversations for this workspace)\",\n        list_elapsed,\n        workspace_ids.len()\n    );\n\n    // Stage 2: fetch_cursor_conversation_from_db for workspace conversations\n    let sample_size = workspace_ids.len().min(50);\n    let sample: Vec<&(String, u64)> = workspace_ids.iter().take(sample_size).collect();\n    let t = Instant::now();\n    let mut fetch_ok = 0u64;\n    let mut fetch_empty = 0u64;\n    let mut fetch_err = 0u64;\n    for (id, _ts) in &sample {\n        match CursorPreset::fetch_cursor_conversation_from_db(&db_path, id) {\n            Ok(Some(_)) => fetch_ok += 1,\n            Ok(None) => fetch_empty += 1,\n            Err(_) => fetch_err += 1,\n        }\n    }\n    let fetch_elapsed = t.elapsed();\n    eprintln!(\n        \"[2] fetch_cursor_conversation_from_db (sample of {}): {:?} (ok={}, empty={}, err={})\",\n        sample_size, fetch_elapsed, fetch_ok, fetch_empty, fetch_err\n    );\n    if sample_size > 0 {\n        eprintln!(\n            \"    avg per conversation: {:?}\",\n            fetch_elapsed / sample_size as u32\n        );\n        if workspace_ids.len() > sample_size {\n            eprintln!(\n                \"    projected for all {}: {:?}\",\n                workspace_ids.len(),\n                fetch_elapsed / sample_size as u32 * workspace_ids.len() as u32\n            );\n        }\n    }\n\n    eprintln!();\n    eprintln!(\"=== Summary ===\");\n    eprintln!(\n        \"Total time: {:?}\",\n        list_elapsed + fetch_elapsed\n    );\n    eprintln!(\"Breakdown:\");\n    eprintln!(\"  list workspace IDs: {:?}\", list_elapsed);\n    eprintln!(\"  fetch (sample):     {:?}\", fetch_elapsed);\n}\n",

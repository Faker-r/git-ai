base: {}\", db_path.display());\n    eprintln!(\"Size: {:.1} MB\", file_size_mb);\n    eprintln!();\n\n    reset_sqlite_open_count();\n\n    // Stage 1: List all conversation IDs\n    let t = Instant::now();\n    let all_ids = CursorPreset::list_all_cursor_conversation_ids(&db_path)\n        .expect(\"Failed to list conversation IDs\");\n    let list_elapsed = t.elapsed();\n    eprintln!(\n        \"[1] list_all_cursor_conversation_ids: {:?} ({} conversations)\",\n        list_elapsed,\n        all_ids.len()\n    );\n\n    // Stage 2: Build workspace composer map\n    let t = Instant::now();\n    let workspace_map = CursorPreset::build_workspace_composer_map();\n    let ws_elapsed = t.elapsed();\n    eprintln!(\n        \"[2] build_workspace_composer_map: {:?} ({} mappings)\",\n        ws_elapsed,\n        workspace_map.len()\n    );\n\n    // Stage 3: get_last_bubble_timestamp for all conversations\n    let t = Instant::now();\n    let mut ts_found = 0u64;\n    let mut ts_missing = 0u64;\n    for id in &all_ids {\n        match CursorPreset::get_last_bubble_timestamp(&db_path, id) {\n            Some(_) => ts_found += 1,\n            None => ts_missing += 1,\n        }\n    }\n    let ts_elapsed = t.elapsed();\n    eprintln!(\n        \"[3] get_last_bubble_timestamp (all {}): {:?} (found={}, missing={})\",\n        all_ids.len(),\n        ts_elapsed,\n        ts_found,\n        ts_missing\n    );\n    if !all_ids.is_empty() {\n        eprintln!(\n            \"    avg per conversation: {:?}\",\n            ts_elapsed / all_ids.len() as u32\n        );\n    }\n\n    // Stage 4: fetch_cursor_conversation_from_db for a sample\n    let sample_size = all_ids.len().min(50);\n    let sample: Vec<&String> = all_ids.iter().take(sample_size).collect();\n    let t = Instant::now();\n    let mut fetch_ok = 0u64;\n    let mut fetch_empty = 0u64;\n    let mut fetch_err = 0u64;\n    for id in &sample {\n        match CursorPreset::fetch_cursor_conversation_from_db(&db_path, id) {\n            Ok(Some(_)) => fetch_ok += 1,\n            Ok(None) => fetch_empty += 1,\n            Err(_) => fetch_err += 1,\n        }\n    }\n    let fetch_elapsed = t.elapsed();\n    eprintln!(\n        \"[4] fetch_cursor_conversation_from_db (sample of {}): {:?} (ok={}, empty={}, err={})\",\n        sample_size, fetch_elapsed, fetch_ok, fetch_empty, fetch_err\n    );\n    if sample_size > 0 {\n        eprintln!(\n            \"    avg per conversation: {:?}\",\n            fetch_elapsed / sample_size as u32\n        );\n        eprintln!(\n            \"    projected for all {}: {:?}\",\n            all_ids.len(),\n            fetch_elapsed / sample_size as u32 * all_ids.len() as u32\n        );\n    }\n\n    // Stage 5: workspace root lookup (fallback path via messageRequestContext)\n    let sample_for_ws: Vec<&String> = all_ids.iter().take(sample_size).collect();\n    let t = Instant::now();\n    let mut ws_found = 0u64;\n    let mut ws_missing = 0u64;\n    for id in &sample_for_ws {\n        match CursorPreset::get_conversation_workspace_root(&db_path, id) {\n            Some(_) => ws_found += 1,\n            None => ws_missing += 1,\n        }\n    }\n    let ws_root_elapsed = t.elapsed();\n    eprintln!(\n        \"[5] get_conversation_workspace_root (sample of {}): {:?} (found={}, missing={})\",\n        sample_size, ws_root_elapsed, ws_found, ws_missing\n    );\n\n    let total_opens = sqlite_open_count();\n    eprintln!();\n    eprintln!(\"=== Summary ===\");\n    eprintln!(\"Total SQLite connection opens: {}\", total_opens);\n    eprintln!(\n        \"Total time: {:?}\",\n        list_elapsed + ws_elapsed + ts_elapsed + fetch_elapsed + ws_root_elapsed\n    );\n    eprintln!(\"Breakdown:\");\n    eprintln!(\"  list IDs:       {:?}\", list_elapsed);\n    eprintln!(\"  workspace map:  {:?}\", ws_elapsed);\n    eprintln!(\"  timestamps:     {:?}\", ts_elapsed);\n    eprintln!(\"  fetch (sample): {:?}\", fetch_elapsed);\n    eprintln!(\"  ws root lookup: {:?}\", ws_root_elapsed);\n}\n",

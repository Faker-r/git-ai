            "231:             let canonical_file_path = file_path_buf.canonicalize().map_err(|e| {",
            "232:                 GitAiError::Generic(format!(",
            "233:                     \"Failed to canonicalize file path '{}': {}\",",
            "234:                     file_path, e",
            "235:                 ))",
            "236:             })?;",
            "237:             let canonical_repo_root = repo_root.canonicalize().map_err(|e| {",
            "238:                 GitAiError::Generic(format!(",
            "239:                     \"Failed to canonicalize repository root '{}': {}\",",
            "240:                     repo_root.display(),",
            "241:                     e",
            "242:                 ))",
            "243:             })?;",
            "244: ",
            "245:             canonical_file_path",

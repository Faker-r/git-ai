            "478: /// Helper: send a ControlRequest over an existing buffered stream and read one response line.",
            "479: fn send_on_persistent_conn<R: Read + Write>(",
            "480:     reader: &mut BufReader<R>,",
            "481:     request: &ControlRequest,",
            "482: ) -> ControlResponse {",
            "483:     let mut body = serde_json::to_vec(request).expect(\"serialize request\");",
            "484:     body.push(b'\\n');",
            "485:     reader",
            "486:         .get_mut()",
            "487:         .write_all(&body)",
            "488:         .expect(\"write request to daemon\");",
            "489:     reader.get_mut().flush().expect(\"flush request\");",
            "490:     let mut line = String::new();",
            "491:     reader",
            "492:         .read_line(&mut line)",
            "493:         .expect(\"read response from daemon\");",
            "494:     assert!(",
            "495:         !line.trim().is_empty(),",
            "496:         \"daemon response should not be empty\"",
            "497:     );",
            "498:     serde_json::from_str::<ControlResponse>(line.trim()).expect(\"parse daemon response\")",
            "499: }",
            "500: ",
            "501: /// Integration test: verifies that a persistent control socket connection can",
            "502: /// deliver telemetry envelopes and CAS payloads to the daemon, and that the",
            "503: /// daemon acknowledges each request with `ok: true` without closing the",
            "504: /// connection between requests.",
            "505: #[test]",
            "506: fn daemon_telemetry_and_cas_over_persistent_connection() {",
            "507:     let repo = TestRepo::new_with_mode(GitTestMode::Wrapper);",
            "508: ",
            "509:     // Start the daemon",
            "510:     let start_output = daemon_command_output(&repo, &[\"d\", \"start\"], repo.path());",
            "511:     assert!(",
            "512:         start_output.status.success(),",
            "513:         \"daemon start should succeed: stdout={} stderr={}\",",
            "514:         String::from_utf8_lossy(&start_output.stdout),",
            "515:         String::from_utf8_lossy(&start_output.stderr)",
            "516:     );",
            "517:     wait_for_daemon_sockets(&repo);",
            "518: ",
            "519:     // Open a single persistent connection (mirrors the shared handle in telemetry_handle.rs)",
            "520:     let control_path = daemon_control_socket_path(&repo);",
            "521:     let stream = open_local_socket_stream_with_timeout(&control_path, Duration::from_secs(2))",
            "522:         .expect(\"should connect to daemon control socket\");",
            "523:     let mut reader = BufReader::new(stream);",
            "524: ",
            "525:     // 1. Send telemetry envelopes (Message + Error variants)",
            "526:     let telemetry_req = ControlRequest::SubmitTelemetry {",
            "527:         envelopes: vec![",
            "528:             TelemetryEnvelope::Message {",
            "529:                 timestamp: \"2026-01-01T00:00:00Z\".to_string(),",
            "530:                 message: \"integration test message\".to_string(),",
            "531:                 level: \"info\".to_string(),",
            "532:                 context: None,",
            "533:             },",
            "534:             TelemetryEnvelope::Error {",
            "535:                 timestamp: \"2026-01-01T00:00:01Z\".to_string(),",
            "536:                 message: \"integration test error event\".to_string(),",
            "537:                 context: None,",
            "538:             },",
            "539:         ],",
            "540:     };",
            "541:     let resp = send_on_persistent_conn(&mut reader, &telemetry_req);",
            "542:     assert!(resp.ok, \"telemetry submit should succeed: {:?}\", resp.error);",
            "543: ",
            "544:     // 2. Send CAS payloads over the *same* connection",
            "545:     let cas_req = ControlRequest::SubmitCas {",
            "546:         records: vec![",
            "547:             CasSyncPayload {",
            "548:                 hash: \"abc123\".to_string(),",
            "549:                 data: \"test cas data\".to_string(),",
            "550:                 metadata: None,",
            "551:             },",
            "552:             CasSyncPayload {",
            "553:                 hash: \"def456\".to_string(),",
            "554:                 data: \"more cas data\".to_string(),",
            "555:                 metadata: Some(\"test-meta\".to_string()),",
            "556:             },",
            "557:         ],",
            "558:     };",
            "559:     let resp = send_on_persistent_conn(&mut reader, &cas_req);",
            "560:     assert!(resp.ok, \"CAS submit should succeed: {:?}\", resp.error);",
            "561: ",
            "562:     // 3. Send another batch of telemetry to confirm the connection stays alive",
            "563:     let telemetry_req2 = ControlRequest::SubmitTelemetry {",
            "564:         envelopes: vec![TelemetryEnvelope::Error {",
            "565:             timestamp: \"2026-01-01T00:00:02Z\".to_string(),",
            "566:             message: \"integration test error\".to_string(),",
            "567:             context: None,",
            "568:         }],",
            "569:     };",
            "570:     let resp = send_on_persistent_conn(&mut reader, &telemetry_req2);",
            "571:     assert!(",
            "572:         resp.ok,",
            "573:         \"second telemetry submit should succeed on persistent connection: {:?}\",",
            "574:         resp.error",
            "575:     );",
            "576: ",
            "577:     // 4. Verify the daemon is still healthy via a status request on the same conn",
            "578:     let status_req = ControlRequest::StatusFamily {",
            "579:         repo_working_dir: repo.canonical_path().to_string_lossy().to_string(),",
            "580:     };",
            "581:     let resp = send_on_persistent_conn(&mut reader, &status_req);",
            "582:     assert!(",
            "583:         resp.ok,",
            "584:         \"status request should succeed on persistent connection: {:?}\",",
            "585:         resp.error",
            "586:     );",
            "587: ",
            "588:     // Clean up",
            "589:     drop(reader);",
            "590:     shutdown_daemon(&repo);",
            "591: }",

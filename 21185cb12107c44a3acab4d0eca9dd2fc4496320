            "496: #[test]",
            "497: fn test_agent_blame_json_mixed_human_agent() {",
            "498:     let repo = TestRepo::new();",
            "499: ",
            "500:     // Human commit",
            "501:     commit_as_human(&repo, \"json_mixed.rs\", \"human line\\n\", \"human commit\");",
            "502: ",
            "503:     // Agent commit",
            "504:     commit_as_agent(",
            "505:         &repo,",
            "506:         \"json_mixed.rs\",",
            "507:         \"human line\\nagent line\\n\",",
            "508:         \"Cursor Agent\",",
            "509:         \"cursoragent@cursor.com\",",
            "510:         \"cursor commit\",",
            "511:     );",
            "512: ",
            "513:     let output = repo.git_ai(&[\"blame\", \"--json\", \"json_mixed.rs\"]).unwrap();",
            "514:     let json: serde_json::Value = serde_json::from_str(extract_json(&output)).expect(\"Valid JSON\");",
            "515: ",
            "516:     let lines = json[\"lines\"].as_object().unwrap();",
            "517:     let prompts = json[\"prompts\"].as_object().unwrap();",
            "518: ",
            "519:     // In JSON mode, line_authors uses prompt hashes as names.",
            "520:     // AI-authored lines map to a prompt hash that exists in prompts;",
            "521:     // human-authored lines map to the human author name (not in prompts).",
            "522: ",
            "523:     // Find line 2's value: it may be keyed as \"2\", \"2:2\", or part of a range like \"1-2\"",
            "524:     let mut line2_prompt_hash: Option<String> = None;",
            "525:     for (range_key, val) in lines {",
            "526:         let val_str = val.as_str().unwrap_or(\"\");",
            "527:         // Check if this range covers line 2",
            "528:         if range_key == \"2\" || range_key == \"2:2\" {",
            "529:             line2_prompt_hash = Some(val_str.to_string());",
            "530:         } else if range_key.contains('-') {",
            "531:             let parts: Vec<&str> = range_key.split('-').collect();",
            "532:             if parts.len() == 2",
            "533:                 && let (Ok(start), Ok(end)) = (parts[0].parse::<u32>(), parts[1].parse::<u32>())",
            "534:                 && start <= 2",
            "535:                 && end >= 2",
            "536:             {",
            "537:                 line2_prompt_hash = Some(val_str.to_string());",
            "538:             }",
            "539:         }",
            "540:     }",
            "541: ",
            "542:     let line2_hash = line2_prompt_hash.expect(\"Line 2 should be present in lines map\");",
            "543: ",
            "544:     // The hash should be a key in prompts (indicating AI authorship)",
            "545:     assert!(",
            "546:         prompts.contains_key(&line2_hash),",
            "547:         \"Line 2's value '{}' should be a prompt hash in prompts, prompts keys: {:?}\",",
            "548:         line2_hash,",
            "549:         prompts.keys().collect::<Vec<_>>()",
            "550:     );",
            "551: ",
            "552:     // The prompt should have tool=cursor",
            "553:     let prompt = &prompts[&line2_hash];",
            "554:     assert_eq!(",
            "555:         prompt[\"agent_id\"][\"tool\"].as_str().unwrap(),",
            "556:         \"cursor\",",
            "557:         \"Prompt should have tool=cursor\"",
            "558:     );",
            "559: }",

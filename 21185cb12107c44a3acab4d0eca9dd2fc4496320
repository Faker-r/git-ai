            "1876:     // Parse timezone string like +0200 or -0500",
            "1877:     let offset = if author_tz.len() == 5 {",
            "1878:         let sign = if &author_tz[0..1] == \"+\" { 1 } else { -1 };",
            "1879:         let hours: i32 = author_tz[1..3].parse().unwrap_or(0);",
            "1880:         let mins: i32 = author_tz[3..5].parse().unwrap_or(0);",
            "1881:         FixedOffset::east_opt(sign * (hours * 3600 + mins * 60))",
            "1882:             .unwrap_or(FixedOffset::east_opt(0).unwrap())",
            "1883:     } else {",
            "1884:         FixedOffset::east_opt(0).unwrap()",
            "1885:     };",
            "1886: ",
            "1887:     let dt = offset.from_utc_datetime(&dt.naive_utc());",
            "1888: ",
            "1889:     // Format date according to options (default: iso)",
            "1890:     if let Some(fmt) = &options.date_format {",
            "1891:         // TODO: support all git date formats",
            "1892:         match fmt.as_str() {",
            "1893:             \"iso\" | \"iso8601\" => dt.format(\"%Y-%m-%d %H:%M:%S %z\").to_string(),",
            "1894:             \"short\" => dt.format(\"%Y-%m-%d\").to_string(),",
            "1895:             \"relative\" => format!(\"{} seconds ago\", (Utc::now().timestamp() - author_time)),",
            "1896:             _ => dt.format(\"%Y-%m-%d %H:%M:%S %z\").to_string(),",
            "1897:         }",
            "1898:     } else {",
            "1899:         dt.format(\"%Y-%m-%d %H:%M:%S %z\").to_string()",
            "1900:     }",
            "1901: }",

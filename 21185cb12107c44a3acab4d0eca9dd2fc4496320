            "935:                 let mut line_authors: Vec<Option<String>> = Vec::with_capacity(num_lines as usize);",
            "936: ",
            "937:                 for i in 0..num_lines {",
            "938:                     let orig_line_num = hunk.orig_range.0 + i;",
            "939: ",
            "940:                     let human_author = if let Some((_author, _prompt_hash, Some(prompt_record))) =",
            "941:                         authorship_log.get_line_attribution(",
            "942:                             self,",
            "943:                             file_path,",
            "944:                             orig_line_num,",
            "945:                             &mut foreign_prompts_cache,",
            "946:                         ) {",
            "947:                         prompt_record.human_author.clone()",
            "948:                     } else {",
            "949:                         None",
            "950:                     };",
            "951:                     line_authors.push(human_author);",
            "952:                 }",
            "953: ",
            "954:                 if options.split_hunks_by_ai_author {",
            "955:                     // Split hunk by consecutive lines with the same human_author",
            "956:                     let mut current_start_idx: u32 = 0;",
            "957:                     let mut current_author = line_authors.first().cloned().flatten();",
            "958: ",
            "959:                     for (i, author) in line_authors.iter().enumerate() {",

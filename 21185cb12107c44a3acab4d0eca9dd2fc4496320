            "852:                     // Defensive: if no current hunk, start one with size 1",
            "853:                     cur_commit = Some(sha.to_string());",
            "854:                     cur_orig_start = p2.parse::<u32>().unwrap_or(0);",
            "855:                     cur_final_start = p3.parse::<u32>().unwrap_or(0);",
            "856:                     cur_group_size = 1;",
            "857:                 }",
            "858:             }",
            "859:         }",
            "860: ",
            "861:         // Flush the final hunk if present",
            "862:         if let Some(prev_sha) = cur_commit.take() {",
            "863:             let start = cur_final_start;",
            "864:             let end = if cur_group_size > 0 {",

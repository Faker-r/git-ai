            "248:                     GitAiError::Generic(format!(",
            "249:                         \"File path '{}' is not within repository root '{}'\",",
            "250:                         file_path,",
            "251:                         repo_root.display()",
            "252:                     ))",
            "253:                 })?",
            "254:                 .to_string_lossy()",
            "255:                 .to_string()",
            "256:         } else {",
            "257:             file_path.to_string()",
            "258:         };",
            "259: ",
            "260:         // Normalize path separators and leading ./.",
            "261:         #[cfg(windows)]",
            "262:         let relative_file_path = {",
            "263:             let normalized = normalize_to_posix(&relative_file_path);",
            "264:             normalized",
            "265:                 .strip_prefix(\"./\")",
            "266:                 .unwrap_or(&normalized)",
            "267:                 .to_string()",
            "268:         };",
            "269: ",
            "270:         #[cfg(not(windows))]",
            "271:         let relative_file_path = {",
            "272:             relative_file_path",
            "273:                 .strip_prefix(\"./\")",
            "274:                 .unwrap_or(&relative_file_path)",
            "275:                 .to_string()",
            "276:         };",
            "277: ",

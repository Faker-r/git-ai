            "596: ",
            "597: /// Helper: create a WrapperDaemon repo with AI content, commit, and return the",
            "598: /// combined stdout+stderr output from the wrapper binary.",
            "599: fn async_commit_with_ai_content(extra_envs: &[(&str, &str)]) -> (TestRepo, String) {",
            "600:     let repo = TestRepo::new_with_mode(GitTestMode::WrapperDaemon);",
            "601: ",
            "602:     // Base commit (human only).",
            "603:     let mut file = repo.filename(\"test.txt\");",
            "604:     file.set_contents(crate::lines![\"Base line 1\", \"Base line 2\"]);",
            "605:     repo.stage_all_and_commit(\"Base commit\").unwrap();",
            "606: ",
            "607:     // Add AI-attributed lines.",
            "608:     file.insert_at(2, crate::lines![\"AI line 1\".ai(), \"AI line 2\".ai()]);",
            "609: ",
            "610:     // Commit via git_with_env so we get the raw output (not NewCommit which",
            "611:     // adds its own sync + note check). We pass GIT_AI_TEST_FORCE_TTY so",
            "612:     // the wrapper treats this pipe as an interactive terminal.",
            "613:     repo.git(&[\"add\", \"-A\"]).expect(\"add should succeed\");",
            "614:     let mut envs: Vec<(&str, &str)> = vec![(\"GIT_AI_TEST_FORCE_TTY\", \"1\")];",
            "615:     envs.extend_from_slice(extra_envs);",
            "616:     let output = repo",
            "617:         .git_with_env(&[\"commit\", \"-m\", \"AI additions\"], &envs, None)",
            "618:         .expect(\"commit should succeed\");",
            "619:     (repo, output)",
            "620: }",

            "new_string": "/// Enumerate commits in `<start>^..<end>`, newest-first.\n///\n/// `<start>^..<end>` is git's conventional \"both endpoints inclusive\" range\n/// syntax. It will fail if `<start>` is a root commit (since `<start>^` doesn't\n/// resolve); callers passing a root commit should pass `<start>` as `<end>` of\n/// a separate single-commit query instead.\n///\n/// Uses git log's default output format and parses it directly.\nfn git_log_commits(\n    repo: &Repository,\n    start: &str,\n    end: &str,\n) -> Result<Vec<CommitInfo>, GitAiError> {\n    let mut args = repo.global_args_for_exec();\n    args.extend([\n        \"log\".to_string(),\n        format!(\"{}^..{}\", start, end),\n    ]);\n    let output = exec_git(&args)?;\n    let stdout = String::from_utf8_lossy(&output.stdout);\n\n    let mut commits = Vec::new();\n    let mut current: Option<CommitInfo> = None;\n    let mut subject_captured = false;\n\n    for output_line in stdout.lines() {\n        if let Some(rest) = output_line.strip_prefix(\"commit \") {\n            if let Some(c) = current.take() {\n                commits.push(c);\n            }\n            let sha = rest.split_whitespace().next().unwrap_or(\"\").to_string();\n            current = Some(CommitInfo {\n                sha,\n                date: String::new(),\n                subject: String::new(),\n            });\n            subject_captured = false;\n        } else if let Some(c) = current.as_mut() {\n            if let Some(d) = output_line.strip_prefix(\"Date:\") {\n                c.date = d.trim().to_string();\n            } else if !subject_captured\n                && let Some(sub) = output_line.strip_prefix(\"    \")\n                && !sub.is_empty()\n            {\n                c.subject = sub.to_string();\n                subject_captured = true;\n            }\n        }\n    }\n    if let Some(c) = current.take() {\n        commits.push(c);\n    }\n    Ok(commits)\n}",
            "old_string": "/// Enumerate commits in `start..end`, inclusive on both ends, newest-first.\n///\n/// Uses `git log <end> --not <start>^@`: exclude everything reachable from any\n/// parent of `<start>` (so `<start>` itself is kept). For a root commit `<start>`,\n/// `^@` resolves to an empty parent set, leaving the full history of `<end>`.\nfn git_log_commits(\n    repo: &Repository,\n    start: &str,\n    end: &str,\n) -> Result<Vec<CommitInfo>, GitAiError> {\n    let mut args = repo.global_args_for_exec();\n    args.extend([\n        \"log\".to_string(),\n        \"--format=%H %aI %s\".to_string(),\n        end.to_string(),\n        \"--not\".to_string(),\n        format!(\"{}^@\", start),\n    ]);\n    let output = exec_git(&args)?;\n    let stdout = String::from_utf8_lossy(&output.stdout);\n\n    let mut commits = Vec::new();\n    for output_line in stdout.lines() {\n        let Some(sha) = output_line.get(..40) else { continue };\n        let Some(rest) = output_line.get(41..) else { continue };\n        let Some((date, subject)) = rest.split_once(' ') else { continue };\n        commits.push(CommitInfo {\n            sha: sha.to_string(),\n            date: date.to_string(),\n            subject: subject.to_string(),\n        });\n    }\n    Ok(commits)\n}",

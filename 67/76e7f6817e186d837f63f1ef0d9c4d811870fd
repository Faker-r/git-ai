            "content": "from pydantic import BaseModel\nfrom typing import Any\n\n\n# --- CAS ---\n\nclass CasObject(BaseModel):\n    content: Any  # JSON value\n    hash: str  # SHA-256 hex of RFC 8785 canonicalized content\n    metadata: dict[str, Any] = {}\n\n\nclass CasUploadRequest(BaseModel):\n    objects: list[CasObject]\n\n\nclass CasObjectResult(BaseModel):\n    hash: str\n    status: str  # \"ok\" or \"error\"\n    error: str | None = None\n    content: Any | None = None  # Only present in read responses\n\n\nclass CasUploadResponse(BaseModel):\n    results: list[CasObjectResult]\n    success_count: int\n    failure_count: int\n\n\nclass CasReadResponse(BaseModel):\n    results: list[CasObjectResult]\n    success_count: int\n    failure_count: int\n\n\n# --- Metrics ---\n\nclass MetricEvent(BaseModel):\n    t: int  # Unix timestamp\n    e: int  # Event type ID\n    v: dict[str, Any] = {}  # Sparse position-encoded values\n    a: dict[str, Any] = {}  # Sparse position-encoded attributes\n\n\nclass MetricsBatch(BaseModel):\n    v: int  # API version, must be 1\n    events: list[MetricEvent]\n\n\nclass MetricsError(BaseModel):\n    index: int\n    error: str\n\n\nclass MetricsUploadResponse(BaseModel):\n    errors: list[MetricsError]\n\n\n# --- Bundles ---\n\nclass CreateBundleRequest(BaseModel):\n    title: str\n    data: dict[str, Any]\n\n\nclass CreateBundleResponse(BaseModel):\n    success: bool\n    id: str\n    url: str\n",

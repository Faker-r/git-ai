            "423:     fn blame_requested_abbrev_len(options: &GitAiBlameOptions, is_boundary: bool) -> usize {",
            "424:         let base_len = options.abbrev.unwrap_or(7).max(1) as usize;",
            "425:         if is_boundary && !options.show_root {",
            "426:             base_len",
            "427:         } else {",
            "428:             (base_len + 1).min(40)",
            "429:         }",
            "430:     }",
            "431: ",
            "432:     fn fallback_blame_abbrev_sha(commit_sha: &str, requested_len: usize) -> String {",
            "433:         if requested_len < commit_sha.len() {",
            "434:             commit_sha[..requested_len].to_string()",
            "435:         } else {",
            "436:             commit_sha.to_string()",
            "437:         }",
            "438:     }",
            "439: ",
            "440:     fn resolve_blame_abbrev_shas_batched(",
            "441:         &self,",
            "442:         requests_by_len: &HashMap<usize, Vec<String>>,",
            "443:     ) -> HashMap<(String, usize), String> {",
            "444:         let mut resolved: HashMap<(String, usize), String> = HashMap::new();",
            "445: ",
            "446:         for (&requested_len, commit_shas) in requests_by_len {",
            "447:             if commit_shas.is_empty() {",
            "448:                 continue;",
            "449:             }",
            "450: ",
            "451:             for commit_sha_batch in commit_shas.chunks(Self::BLAME_ABBREV_BATCH_SIZE) {",
            "452:                 let mut args = self.global_args_for_exec();",
            "453:                 args.push(\"rev-parse\".to_string());",
            "454:                 args.push(format!(\"--short={requested_len}\"));",
            "455:                 args.extend(commit_sha_batch.iter().cloned());",
            "456: ",
            "457:                 let batched_result = exec_git(&args)",
            "458:                     .ok()",
            "459:                     .and_then(|output| String::from_utf8(output.stdout).ok())",
            "460:                     .map(|stdout| {",
            "461:                         stdout",
            "462:                             .lines()",
            "463:                             .map(str::trim)",
            "464:                             .filter(|line| !line.is_empty())",
            "465:                             .map(str::to_string)",
            "466:                             .collect::<Vec<_>>()",
            "467:                     });",
            "468: ",
            "469:                 if let Some(short_shas) = batched_result",
            "470:                     && short_shas.len() == commit_sha_batch.len()",
            "471:                 {",
            "472:                     for (commit_sha, short_sha) in commit_sha_batch.iter().zip(short_shas) {",
            "473:                         resolved.insert((commit_sha.clone(), requested_len), short_sha);",
            "474:                     }",
            "475:                     continue;",
            "476:                 }",
            "477: ",
            "478:                 for commit_sha in commit_sha_batch {",
            "479:                     resolved",
            "480:                         .entry((commit_sha.clone(), requested_len))",
            "481:                         .or_insert_with(|| {",
            "482:                             Self::fallback_blame_abbrev_sha(commit_sha, requested_len)",
            "483:                         });",
            "484:                 }",
            "485:             }",
            "486:         }",
            "487: ",
            "488:         resolved",
            "489:     }",
            "490: ",
            "491:     fn populate_hunk_abbrev_shas(&self, hunks: &mut [BlameHunk], options: &GitAiBlameOptions) {",
            "492:         if options.long_rev {",
            "493:             for hunk in hunks {",
            "494:                 hunk.abbrev_sha = hunk.commit_sha.clone();",
            "495:             }",
            "496:             return;",
            "497:         }",
            "498: ",
            "499:         let mut requests_by_len: HashMap<usize, Vec<String>> = HashMap::new();",
            "500:         let mut seen_by_len: HashMap<usize, HashSet<String>> = HashMap::new();",
            "501: ",
            "502:         for hunk in hunks.iter() {",
            "503:             let requested_len = Self::blame_requested_abbrev_len(options, hunk.is_boundary);",
            "504:             let seen = seen_by_len.entry(requested_len).or_default();",
            "505:             if seen.insert(hunk.commit_sha.clone()) {",
            "506:                 requests_by_len",
            "507:                     .entry(requested_len)",
            "508:                     .or_default()",
            "509:                     .push(hunk.commit_sha.clone());",
            "510:             }",
            "511:         }",
            "512: ",
            "513:         let resolved = self.resolve_blame_abbrev_shas_batched(&requests_by_len);",
            "514: ",
            "515:         for hunk in hunks.iter_mut() {",
            "516:             let requested_len = Self::blame_requested_abbrev_len(options, hunk.is_boundary);",
            "517:             hunk.abbrev_sha = resolved",
            "518:                 .get(&(hunk.commit_sha.clone(), requested_len))",
            "519:                 .cloned()",
            "520:                 .unwrap_or_else(|| {",
            "521:                     Self::fallback_blame_abbrev_sha(&hunk.commit_sha, requested_len)",
            "522:                 });",
            "523:         }",
            "524:     }",

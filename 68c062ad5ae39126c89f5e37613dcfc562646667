            "619: ",
            "620:     pub fn blame_hunks_for_ranges(",
            "621:         &self,",
            "622:         file_path: &str,",
            "623:         line_ranges: &[(u32, u32)],",
            "624:         options: &GitAiBlameOptions,",
            "625:     ) -> Result<Vec<BlameHunk>, GitAiError> {",
            "626:         if line_ranges.is_empty() {",
            "627:             return Ok(Vec::new());",
            "628:         }",
            "629: ",
            "630:         // Build git blame --line-porcelain command",
            "631:         let mut args = self.global_args_for_exec();",
            "632:         args.push(\"blame\".to_string());",
            "633:         args.push(\"--line-porcelain\".to_string());",
            "634: ",
            "635:         // Ignore whitespace option",
            "636:         if options.ignore_whitespace {",
            "637:             args.push(\"-w\".to_string());",
            "638:         }",
            "639: ",
            "640:         // Respect ignore options in use",
            "641:         for rev in &options.ignore_revs {",
            "642:             args.push(\"--ignore-rev\".to_string());",
            "643:             args.push(rev.clone());",
            "644:         }",
            "645:         if let Some(file) = &options.ignore_revs_file {",
            "646:             args.push(\"--ignore-revs-file\".to_string());",
            "647:             args.push(file.clone());",
            "648:         }",
            "649: ",
            "650:         // Limit to the specified ranges (git blame supports multiple -L flags).",
            "651:         for (start_line, end_line) in line_ranges {",
            "652:             args.push(\"-L\".to_string());",
            "653:             args.push(format!(\"{},{}\", start_line, end_line));",
            "654:         }",
            "655: ",
            "656:         // Add --since flag if oldest_date is specified",
            "657:         // This controls the absolute lower bound of how far back to look",
            "658:         if let Some(ref date_spec) = options.oldest_date_spec {",
            "659:             args.push(\"--since\".to_string());",
            "660:             args.push(date_spec.clone());",
            "661:         } else if let Some(ref date) = options.oldest_date {",
            "662:             args.push(\"--since\".to_string());",
            "663:             args.push(date.to_rfc3339());",
            "664:         }",
            "665: ",
            "666:         // Support newest_commit option (equivalent to libgit2's newest_commit)",
            "667:         // This limits blame to only consider commits up to and including the specified commit",
            "668:         // When oldest_commit is also set, we use a range: oldest_commit..newest_commit",
            "669:         match (&options.oldest_commit, &options.newest_commit) {",
            "670:             (Some(oldest), Some(newest)) => {",
            "671:                 // Use range format: git blame START_COMMIT..END_COMMIT -- file.txt",
            "672:                 args.push(format!(\"{}..{}\", oldest, newest));",
            "673:             }",
            "674:             (None, Some(newest)) => {",
            "675:                 // Only newest_commit set, use it as the commit to blame at",
            "676:                 args.push(newest.clone());",
            "677:             }",
            "678:             (Some(_oldest), None) => {",
            "679:                 // oldest_commit without newest_commit doesn't make sense for blame",
            "680:                 // Just ignore oldest_commit in this case",
            "681:             }",
            "682:             (None, None) => {",
            "683:                 // No commit specified, blame at HEAD (default)",
            "684:             }",
            "685:         }",
            "686: ",
            "687:         // Add --contents flag if we have content data to pass via stdin",
            "688:         if options.contents_data.is_some() {",
            "689:             args.push(\"--contents\".to_string());",
            "690:             args.push(\"-\".to_string());",
            "691:         }",
            "692: ",
            "693:         args.push(\"--\".to_string());",
            "694:         args.push(file_path.to_string());",
            "695: ",
            "696:         // Execute git blame, using stdin if we have contents data",
            "697:         let output = if let Some(ref data) = options.contents_data {",
            "698:             exec_git_stdin(&args, data)?",
            "699:         } else {",
            "700:             exec_git(&args)?",
            "701:         };",
            "702:         let stdout = String::from_utf8_lossy(&output.stdout).into_owned();",
            "703: ",
            "704:         // Parser state for current hunk",
            "705:         #[derive(Default)]",
            "706:         struct CurMeta {",
            "707:             author: String,",
            "708:             author_mail: String,",
            "709:             author_time: i64,",
            "710:             author_tz: String,",
            "711:             committer: String,",
            "712:             committer_mail: String,",
            "713:             committer_time: i64,",
            "714:             committer_tz: String,",
            "715:             boundary: bool,",
            "716:         }",
            "717: ",
            "718:         let mut hunks: Vec<BlameHunk> = Vec::new();",
            "719:         let mut cur_commit: Option<String> = None;",
            "720:         let mut cur_final_start: u32 = 0;",
            "721:         let mut cur_orig_start: u32 = 0;",
            "722:         let mut cur_group_size: u32 = 0;",
            "723:         let mut cur_meta = CurMeta::default();",
            "724: ",
            "725:         for line in stdout.lines() {",
            "726:             if line.is_empty() {",
            "727:                 continue;",
            "728:             }",
            "729: ",
            "730:             if line.starts_with('\\t') {",
            "731:                 // Content line; nothing to do, boundaries are driven by headers",
            "732:                 continue;",
            "733:             }",
            "734: ",
            "735:             // Metadata lines",
            "736:             if let Some(rest) = line.strip_prefix(\"author \") {",
            "737:                 cur_meta.author = rest.to_string();",
            "738:                 continue;",
            "739:             }",
            "740:             if let Some(rest) = line.strip_prefix(\"author-mail \") {",
            "741:                 // Usually in form: <mail>",
            "742:                 cur_meta.author_mail = rest",
            "743:                     .trim()",
            "744:                     .trim_start_matches('<')",
            "745:                     .trim_end_matches('>')",
            "746:                     .to_string();",
            "747:                 continue;",
            "748:             }",
            "749:             if let Some(rest) = line.strip_prefix(\"author-time \") {",
            "750:                 if let Ok(t) = rest.trim().parse::<i64>() {",
            "751:                     cur_meta.author_time = t;",
            "752:                 }",
            "753:                 continue;",
            "754:             }",
            "755:             if let Some(rest) = line.strip_prefix(\"author-tz \") {",
            "756:                 cur_meta.author_tz = rest.trim().to_string();",
            "757:                 continue;",
            "758:             }",
            "759:             if let Some(rest) = line.strip_prefix(\"committer \") {",
            "760:                 cur_meta.committer = rest.to_string();",
            "761:                 continue;",
            "762:             }",
            "763:             if let Some(rest) = line.strip_prefix(\"committer-mail \") {",
            "764:                 cur_meta.committer_mail = rest",
            "765:                     .trim()",
            "766:                     .trim_start_matches('<')",
            "767:                     .trim_end_matches('>')",
            "768:                     .to_string();",
            "769:                 continue;",
            "770:             }",
            "771:             if let Some(rest) = line.strip_prefix(\"committer-time \") {",
            "772:                 if let Ok(t) = rest.trim().parse::<i64>() {",
            "773:                     cur_meta.committer_time = t;",
            "774:                 }",
            "775:                 continue;",
            "776:             }",
            "777:             if let Some(rest) = line.strip_prefix(\"committer-tz \") {",
            "778:                 cur_meta.committer_tz = rest.trim().to_string();",
            "779:                 continue;",
            "780:             }",
            "781:             if line == \"boundary\" {",
            "782:                 cur_meta.boundary = true;",
            "783:                 continue;",
            "784:             }",
            "785: ",
            "786:             // Header line: either 4 fields (new hunk) or 3 fields (continuation)",
            "787:             let mut parts = line.split_whitespace();",
            "788:             let sha = parts.next().unwrap_or(\"\");",
            "789:             let p2 = parts.next().unwrap_or(\"\");",
            "790:             let p3 = parts.next().unwrap_or(\"\");",
            "791:             let p4 = parts.next();",
            "792: ",
            "793:             let is_header = !sha.is_empty()",
            "794:                 && sha.chars().all(|c| c.is_ascii_hexdigit())",
            "795:                 && !p2.is_empty()",
            "796:                 && !p3.is_empty();",
            "797:             if !is_header {",
            "798:                 continue;",
            "799:             }",
            "800: ",
            "801:             // If we encounter a new hunk header (4 fields), flush previous hunk first",
            "802:             if p4.is_some() {",
            "803:                 if let Some(prev_sha) = cur_commit.take() {",
            "804:                     // Push the previous hunk",
            "805:                     let start = cur_final_start;",
            "806:                     let end = if cur_group_size > 0 {",
            "807:                         start + cur_group_size - 1",
            "808:                     } else {",
            "809:                         start",
            "810:                     };",
            "811:                     let orig_start = cur_orig_start;",
            "812:                     let orig_end = if cur_group_size > 0 {",
            "813:                         orig_start + cur_group_size - 1",
            "814:                     } else {",
            "815:                         orig_start",
            "816:                     };",
            "817: ",
            "818:                     hunks.push(BlameHunk {",
            "819:                         range: (start, end),",
            "820:                         orig_range: (orig_start, orig_end),",
            "821:                         commit_sha: prev_sha,",
            "822:                         abbrev_sha: String::new(),",
            "823:                         original_author: cur_meta.author.clone(),",
            "824:                         author_email: cur_meta.author_mail.clone(),",
            "825:                         author_time: cur_meta.author_time,",
            "826:                         author_tz: cur_meta.author_tz.clone(),",
            "827:                         ai_human_author: None,",
            "828:                         committer: cur_meta.committer.clone(),",
            "829:                         committer_email: cur_meta.committer_mail.clone(),",
            "830:                         committer_time: cur_meta.committer_time,",
            "831:                         committer_tz: cur_meta.committer_tz.clone(),",
            "832:                         is_boundary: cur_meta.boundary,",
            "833:                     });",
            "834:                 }",
            "835: ",
            "836:                 // Start new hunk",
            "837:                 cur_commit = Some(sha.to_string());",
            "838:                 // According to docs: fields are orig_lineno, final_lineno, group_size",
            "839:                 let orig_start = p2.parse::<u32>().unwrap_or(0);",
            "840:                 let final_start = p3.parse::<u32>().unwrap_or(0);",
            "841:                 let group = p4.unwrap_or(\"1\").parse::<u32>().unwrap_or(1);",
            "842:                 cur_orig_start = orig_start;",
            "843:                 cur_final_start = final_start;",
            "844:                 cur_group_size = group;",
            "845:                 // Reset metadata for the new hunk",
            "846:                 cur_meta = CurMeta::default();",
            "847:             } else {",
            "848:                 // 3-field header: continuation line within current hunk",
            "849:                 // Nothing to do for grouping since we use recorded group_size",
            "850:                 // Metadata remains from the first line of the hunk",
            "851:                 if cur_commit.is_none() {",
            "852:                     // Defensive: if no current hunk, start one with size 1",
            "853:                     cur_commit = Some(sha.to_string());",
            "854:                     cur_orig_start = p2.parse::<u32>().unwrap_or(0);",
            "855:                     cur_final_start = p3.parse::<u32>().unwrap_or(0);",
            "856:                     cur_group_size = 1;",
            "857:                 }",
            "858:             }",
            "859:         }",
            "860: ",
            "861:         // Flush the final hunk if present",
            "862:         if let Some(prev_sha) = cur_commit.take() {",
            "863:             let start = cur_final_start;",
            "864:             let end = if cur_group_size > 0 {",
            "865:                 start + cur_group_size - 1",
            "866:             } else {",
            "867:                 start",
            "868:             };",
            "869:             let orig_start = cur_orig_start;",
            "870:             let orig_end = if cur_group_size > 0 {",
            "871:                 orig_start + cur_group_size - 1",
            "872:             } else {",
            "873:                 orig_start",
            "874:             };",
            "875: ",
            "876:             hunks.push(BlameHunk {",
            "877:                 range: (start, end),",
            "878:                 orig_range: (orig_start, orig_end),",
            "879:                 commit_sha: prev_sha,",
            "880:                 abbrev_sha: String::new(),",
            "881:                 original_author: cur_meta.author.clone(),",
            "882:                 author_email: cur_meta.author_mail.clone(),",
            "883:                 author_time: cur_meta.author_time,",
            "884:                 author_tz: cur_meta.author_tz.clone(),",
            "885:                 ai_human_author: None,",
            "886:                 committer: cur_meta.committer.clone(),",
            "887:                 committer_email: cur_meta.committer_mail.clone(),",
            "888:                 committer_time: cur_meta.committer_time,",
            "889:                 committer_tz: cur_meta.committer_tz.clone(),",
            "890:                 is_boundary: cur_meta.boundary,",
            "891:             });",
